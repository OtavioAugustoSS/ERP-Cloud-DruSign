generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model client {
  id        String   @id
  name      String
  email     String?  @unique(map: "Client_email_key")
  phone     String?
  document  String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  order     order[]
}

model log {
  id        String   @id
  userId    String
  action    String
  timestamp DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id], map: "Log_userId_fkey")

  @@index([userId], map: "Log_userId_fkey")
}

model notification {
  id            String   @id
  recipientRole String
  message       String
  read          Boolean  @default(false)
  orderId       String?
  createdAt     DateTime @default(now())
}

model order {
  id                 String       @id
  clientId           String?
  clientName         String?
  clientDocument     String?
  clientIe           String?
  clientPhone        String?
  clientZip          String?
  clientStreet       String?
  clientNumber       String?
  clientNeighborhood String?
  clientCity         String?
  clientState        String?
  filePaths          Json?
  status             order_status @default(PENDING)
  serviceValue       Float?       @default(0)
  totalPrice         Float
  shippingCost       Float        @default(0)
  discount           Float        @default(0)
  approvalDate       DateTime?
  deliveryDate       DateTime?
  paymentTerms       String?
  deliveryMethod     String?
  notes              String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime
  client             client?      @relation(fields: [clientId], references: [id], map: "Order_clientId_fkey")
  orderitem          orderitem[]

  @@index([clientId], map: "Order_clientId_fkey")
}

model orderitem {
  id            String   @id
  orderId       String
  productId     String?
  width         Float?
  height        Float?
  quantity      Int
  unitPrice     Float    @default(0)
  totalPrice    Float    @default(0)
  serviceType   String?
  finishing     String?
  instructions  String?
  observations  String?
  customDetails String?
  material      String?
  fileUrl       String?
  order         order    @relation(fields: [orderId], references: [id], map: "OrderItem_orderId_fkey")
  product       product? @relation(fields: [productId], references: [id], map: "OrderItem_productId_fkey")

  @@index([orderId], map: "OrderItem_orderId_fkey")
  @@index([productId], map: "OrderItem_productId_fkey")
}

model product {
  id            String      @id
  name          String
  category      String
  pricePerM2    Float
  description   String?
  image         String?
  pricingConfig Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime
  orderitem     orderitem[]
}

model systemsettings {
  id             String   @id
  companyName    String   @default("Minha Gráfica")
  companyCnpj    String?
  companyPhone   String?
  companyEmail   String?
  companyAddress String?
  priceSettings  String?
  updatedAt      DateTime
}

model user {
  id        String    @id
  email     String    @unique(map: "User_email_key")
  name      String
  password  String
  role      user_role @default(employee)
  phone     String?
  image     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  log       log[]
}

enum user_role {
  admin
  employee
}

enum order_status {
  PENDING
  IN_PRODUCTION
  FINISHING
  READY_FOR_SHIPPING
  COMPLETED
  CANCELLED
}
