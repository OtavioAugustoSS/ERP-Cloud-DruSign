# DruSign ERP — Environment Variables
# Copie este arquivo para `.env` e preencha com valores reais.
# NUNCA commite `.env`. Gere secrets fortes antes de rodar em qualquer ambiente.

# ------------------------------------------------------------------------
# Banco de dados MySQL
# Formato: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Use um usuário dedicado ao app (não `root`) e uma senha longa.
# ------------------------------------------------------------------------
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/drusign"

# ------------------------------------------------------------------------
# JWT
# Gere com: openssl rand -base64 32
# Tamanho mínimo: 32 bytes (44 chars em base64).
# Trocar o secret invalida todas as sessões ativas.
# ------------------------------------------------------------------------
JWT_SECRET=""

# Tempo de vida da sessão em SEGUNDOS.
# Default: 86400 (24h). Mínimo aceito: 900 (15min). Máximo: 2592000 (30 dias).
# Valor inválido cai no default automaticamente.
JWT_EXPIRES_IN_SECONDS="86400"

# ------------------------------------------------------------------------
# Rate limit do login
# Bloqueia tentativas de força-bruta por email E por IP.
# ------------------------------------------------------------------------
LOGIN_MAX_ATTEMPTS="5"
LOGIN_WINDOW_MINUTES="15"

# ------------------------------------------------------------------------
# Upload de arquivos
# Limites aplicados em src/actions/upload.ts.
# ------------------------------------------------------------------------
UPLOAD_MAX_FILE_MB="10"
UPLOAD_MAX_FILES="20"

# ------------------------------------------------------------------------
# Ambiente
# "development" | "production" | "test"
# Em production: cookies viram Secure, CSP fica estrito (sem 'unsafe-eval'),
# HSTS é enviado. Nunca rode com NODE_ENV=development em produção.
# ------------------------------------------------------------------------
NODE_ENV="development"

# ------------------------------------------------------------------------
# Seed do admin inicial (usado por `prisma/seed.ts` — ver FASE 2)
# Defina antes de rodar `npm run db:seed`.
# A senha é hasheada com bcrypt antes de ir para o banco e
# DEVE atender à política mínima (8+ chars, maiúscula, minúscula, número).
# ------------------------------------------------------------------------
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
